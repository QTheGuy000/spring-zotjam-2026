--- !u!114 &222921210
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 222921208}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 496a593093e06c84b95385b4f4c979e4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  dialogues:
  - 'It has been 5 years since Remy opened his very own restaurant, La Ratatouille,
    but he has hit a plateau. He needs a new dish like never before; one that can
    bring down the mightiest of chefs and leave his name forever embedded in history. '
  - 'That is when he heard a conspiracy through the rat channel, which is leagues
    more reliable than any of those human news networks (you know who you are). '
  - 'The moon is made of cheese, and it has been aging for billions of years into
    a delicacy that could yield the creamiest and richest fondue that the world has
    ever known. The Murican government has been hiding this fact, and they launched
    their newest ship, the Muskrat II, in order to guard it. '
  timeBtwnChars: 0.03
  timeBtwnWords: 0.03
