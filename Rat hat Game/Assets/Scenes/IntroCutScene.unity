  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 496a593093e06c84b95385b4f4c979e4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  dialogues:
  - "Statue: \u201CI thank you for bringing me back to life, little rat. But why
    were you scampering underneath the Murican Labs in the first place?\u201D"
  - Remy tells the statue about the moon conspiracy, but conveniently leaves out
    the part about fondue.
  - "Statue: \u201CThis is unacceptable! As Honest Abe, I cannot stand by and watch
    the Murican people being left in the dark!\u201D"
  timeBtwnChars: 0.03
  timeBtwnWords: 0.03
